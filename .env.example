# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
SERVER_PORT=8081
APP_URL=http://localhost:5173
API_URL=http://localhost:8081

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5433/pipeline

# ── Session ──────────────────────────────────────────────────────────────────
PIPELINE_SESSION_SECRET=change-me-to-a-long-random-string

# ── Google OAuth (user login) ────────────────────────────────────────────────
PIPELINE_GOOGLE_CLIENT_ID=
PIPELINE_GOOGLE_CLIENT_SECRET=
PIPELINE_GOOGLE_REDIRECT_URI=http://localhost:8081/api/auth/callback

# ── Domain-Wide Delegation (Gmail/Drive/Calendar sync) ───────────────────────
# Local: path to service account JSON. Production: Secret Manager PIPELINE_SERVICE_ACCOUNT_JSON
GOOGLE_APPLICATION_CREDENTIALS=
PIPELINE_SERVICE_ACCOUNT_JSON=
GCP_PROJECT=phoenician-production

# Leadership mailboxes to sync (comma-separated)
PIPELINE_SYNC_MAILBOXES=sethpoor@phoeniciantech.com,jaredbodily@phoeniciantech.com

# App sign-in whitelist (comma-separated; defaults to leadership mailboxes)
PIPELINE_ALLOWED_USERS=jaredbodily@phoeniciantech.com,sethpoor@phoeniciantech.com

# ── Drive meeting notes folder ───────────────────────────────────────────────
PIPELINE_DRIVE_NOTES_FOLDER_ID=1TnpEzm4C0r0uEZ6rr2ecF11liAgX95m-

# ── Internal sync jobs (Cloud Scheduler / local cron) ────────────────────────
PIPELINE_INTERNAL_SYNC_TOKEN=change-me-for-scheduler

# ── Vertex AI / Gemini ───────────────────────────────────────────────────────
VERTEX_AI_LOCATION=us-west1
VERTEX_ORACLE_MODEL=gemini-2.5-flash
ORACLE_USE_VERTEX_AI=true
# Optional local dev fallback:
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Firestore seed (optional) ──────────────────────────────────────────────────
CHECKLIST_FIRESTORE_COLLECTION=checklist_leads

# ── GitHub repo discovery (optional) ─────────────────────────────────────────
PIPELINE_GITHUB_OWNER=phoeniciantech
PIPELINE_GITHUB_TOKEN=
PIPELINE_GCP_REGION=us-west1
